---
import { ofertaVariants } from '../data/oferta';

const navLinks = [
  { href: '/#o-nas', label: 'O nas' },
  { href: '/oferta/', label: 'Oferta', dropdown: 'oferta' },
  { href: '/#korzysci', label: 'Korzyści' },
  { href: '/#realizacje', label: 'Realizacje' },
  { href: '/#wspolpraca', label: 'Współpraca' },
  { href: '/#kontakt', label: 'Kontakt' },
];
---

<header id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-500">
  <div class="absolute inset-0 backdrop-blur-xl transition-all duration-500" style="background-color: var(--color-overlay);"></div>
  <nav class="relative section-padding">
    <div class="max-w-7xl mx-auto flex items-center justify-between h-16 md:h-20">
      <!-- Logo -->
      <a href="/" class="relative z-10 flex items-center gap-3 group" aria-label="Mekra - strona główna">
        <div class="w-9 h-9 rounded-lg flex items-center justify-center transition-all duration-300" style="background-color: var(--color-accent);">
          <span class="text-white font-display text-lg leading-none">M</span>
        </div>
        <div class="flex flex-col">
          <span class="font-display text-xl tracking-tight leading-none" style="color: var(--color-text);">
            Mekra.pl
          </span>
          <span class="text-[9px] font-body font-medium tracking-[0.15em] uppercase leading-none mt-1" style="color: var(--color-text-muted);">
            Fronty ramiakowe
          </span>
        </div>
      </a>

      <!-- Desktop Nav -->
      <div class="hidden lg:flex items-center gap-1">
        {navLinks.map((link) => (
          link.dropdown === 'oferta' ? (
            <div class="nav-dropdown relative">
              <a
                href={link.href}
                class="nav-dropdown__trigger px-4 py-2 text-sm font-body font-medium rounded-lg transition-all duration-300 hover:text-[var(--color-accent)] inline-flex items-center gap-1"
                style="color: var(--color-text-secondary);"
                aria-haspopup="true"
                aria-expanded="false"
              >
                {link.label}
                <svg class="nav-dropdown__chevron w-3.5 h-3.5 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
                </svg>
              </a>

              <!-- Dropdown panel -->
              <div class="nav-dropdown__panel" role="menu">
                <div class="nav-dropdown__inner">
                  <div class="nav-dropdown__header">
                    <span class="nav-dropdown__eyebrow">Grubości ramek</span>
                    <p class="nav-dropdown__title">Wybierz wariant frontu</p>
                  </div>

                  <div class="nav-dropdown__grid">
                    {ofertaVariants.map((v) => (
                      <a href={`/oferta/${v.slug}/`} class="nav-dropdown__item" role="menuitem">
                        <div class="nav-dropdown__item-icon">
                          {v.unit ? (
                            <Fragment>
                              <span class="nav-dropdown__item-size">{v.size}</span>
                              <span class="nav-dropdown__item-unit">{v.unit}</span>
                            </Fragment>
                          ) : (
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                              <path stroke-linecap="round" stroke-linejoin="round" d="M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.562.562 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.562.562 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z" />
                            </svg>
                          )}
                        </div>
                        <div class="nav-dropdown__item-body">
                          <span class="nav-dropdown__item-name">{v.name}</span>
                          <span class="nav-dropdown__item-desc">{v.tagline}</span>
                        </div>
                        <svg class="nav-dropdown__item-arrow w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                        </svg>
                      </a>
                    ))}
                  </div>

                  <div class="nav-dropdown__footer">
                    <a href="/oferta/" class="nav-dropdown__footer-link">
                      Zobacz pełną ofertę
                      <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                      </svg>
                    </a>
                  </div>
                </div>
              </div>
            </div>
          ) : (
            <a
              href={link.href}
              class="px-4 py-2 text-sm font-body font-medium rounded-lg transition-all duration-300 hover:text-[var(--color-accent)]"
              style="color: var(--color-text-secondary);"
            >
              {link.label}
            </a>
          )
        ))}
      </div>

      <!-- Actions -->
      <div class="flex items-center gap-3">
        <!-- Theme Toggle -->
        <button
          id="theme-toggle"
          aria-label="Przełącz motyw"
          class="relative w-10 h-10 rounded-xl flex items-center justify-center transition-all duration-300 hover:scale-110"
          style="border: 1px solid var(--color-border);"
        >
          <!-- Sun icon -->
          <svg class="w-[18px] h-[18px] hidden dark:block" style="color: var(--color-text-secondary);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z" />
          </svg>
          <!-- Moon icon -->
          <svg class="w-[18px] h-[18px] block dark:hidden" style="color: var(--color-text-secondary);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z" />
          </svg>
        </button>

        <!-- CTA -->
        <a href="/#kontakt" class="hidden sm:inline-flex btn-primary !py-2.5 !px-5 !text-xs">
          Zamów wycenę
        </a>

        <!-- Mobile Menu Toggle -->
        <button
          id="mobile-menu-toggle"
          class="lg:hidden relative w-10 h-10 rounded-xl flex items-center justify-center transition-all duration-300"
          style="border: 1px solid var(--color-border);"
          aria-label="Menu"
        >
          <div class="flex flex-col gap-1.5" id="hamburger-icon">
            <span class="block w-5 h-[1.5px] rounded-full transition-all duration-300" style="background-color: var(--color-text);"></span>
            <span class="block w-5 h-[1.5px] rounded-full transition-all duration-300" style="background-color: var(--color-text);"></span>
          </div>
        </button>
      </div>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    class="lg:hidden fixed inset-x-0 top-16 md:top-20 bottom-0 pointer-events-none opacity-0 transition-all duration-500 -translate-y-4 overflow-y-auto"
    style="background-color: var(--color-bg);"
  >
    <div class="section-padding py-8 flex flex-col gap-2">
      {navLinks.map((link) => (
        link.dropdown === 'oferta' ? (
          <div class="mobile-oferta-group">
            <button
              class="mobile-oferta-toggle w-full flex items-center justify-between px-4 py-3 text-lg font-heading font-medium rounded-xl transition-all duration-300 hover:bg-[var(--color-bg-secondary)]"
              style="color: var(--color-text);"
              aria-expanded="false"
            >
              <span>{link.label}</span>
              <svg class="mobile-oferta-chevron w-5 h-5 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </button>
            <div class="mobile-oferta-panel overflow-hidden transition-all duration-300" style="max-height: 0;">
              <div class="pl-3 pt-1 pb-2 flex flex-col gap-1">
                <a href="/oferta/" class="mobile-nav-link block px-4 py-2.5 text-sm font-body rounded-lg transition-all duration-300 hover:bg-[var(--color-bg-secondary)]" style="color: var(--color-text-secondary);">
                  Wszystkie warianty
                </a>
                {ofertaVariants.map((v) => (
                  <a
                    href={`/oferta/${v.slug}/`}
                    class="mobile-nav-link flex items-center gap-3 px-4 py-2.5 text-sm font-body rounded-lg transition-all duration-300 hover:bg-[var(--color-bg-secondary)]"
                    style="color: var(--color-text-secondary);"
                  >
                    <span class="font-heading font-semibold inline-flex items-baseline gap-0.5 min-w-[2.5rem]" style="color: var(--color-accent);">
                      {v.unit ? (
                        <Fragment>
                          <span>{v.size}</span>
                          <span class="text-xs">{v.unit}</span>
                        </Fragment>
                      ) : (
                        <span class="text-base">★</span>
                      )}
                    </span>
                    <span>{v.name}</span>
                  </a>
                ))}
              </div>
            </div>
          </div>
        ) : (
          <a
            href={link.href}
            class="mobile-nav-link block px-4 py-3 text-lg font-heading font-medium rounded-xl transition-all duration-300 hover:bg-[var(--color-bg-secondary)]"
            style="color: var(--color-text);"
          >
            {link.label}
          </a>
        )
      ))}
      <div class="mt-4 pt-4" style="border-top: 1px solid var(--color-border);">
        <a href="/#kontakt" class="btn-primary w-full text-center">Zamów wycenę</a>
      </div>
    </div>
  </div>
</header>

<style>
  /* ── Desktop dropdown ── */
  .nav-dropdown { position: relative; }

  .nav-dropdown__panel {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 50%;
    transform: translateX(-50%) translateY(-8px);
    width: 28rem;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity 0.25s cubic-bezier(0.4, 0, 0.2, 1),
                transform 0.25s cubic-bezier(0.4, 0, 0.2, 1),
                visibility 0.25s;
    z-index: 60;
  }

  /* Invisible hover bridge so the cursor can travel from trigger to panel */
  .nav-dropdown__panel::before {
    content: '';
    position: absolute;
    top: -0.75rem;
    left: 0;
    right: 0;
    height: 0.75rem;
  }

  .nav-dropdown:hover .nav-dropdown__panel,
  .nav-dropdown:focus-within .nav-dropdown__panel,
  .nav-dropdown.is-open .nav-dropdown__panel {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(0);
  }

  .nav-dropdown:hover .nav-dropdown__chevron,
  .nav-dropdown.is-open .nav-dropdown__chevron {
    transform: rotate(180deg);
  }

  .nav-dropdown:hover .nav-dropdown__trigger,
  .nav-dropdown.is-open .nav-dropdown__trigger {
    color: var(--color-accent) !important;
  }

  .nav-dropdown__inner {
    background-color: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: 1rem;
    padding: 1.25rem;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15),
                0 0 0 1px rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }
  .dark .nav-dropdown__inner {
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5),
                0 0 0 1px rgba(255, 255, 255, 0.04);
  }

  .nav-dropdown__header {
    padding: 0 0.5rem 0.875rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 0.5rem;
  }
  .nav-dropdown__eyebrow {
    font-family: 'Outfit', sans-serif;
    font-size: 0.625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
  }
  .nav-dropdown__title {
    margin-top: 0.25rem;
    font-family: 'DM Serif Display', serif;
    font-size: 1.125rem;
    line-height: 1.2;
    color: var(--color-text);
  }

  .nav-dropdown__grid {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }

  .nav-dropdown__item {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 0.625rem 0.75rem;
    border-radius: 0.625rem;
    text-decoration: none;
    transition: background-color 0.2s ease;
  }
  .nav-dropdown__item:hover {
    background-color: var(--color-bg-secondary);
  }

  .nav-dropdown__item-icon {
    width: 2.75rem;
    height: 2.75rem;
    flex-shrink: 0;
    border-radius: 0.625rem;
    background-color: var(--color-bg-tertiary);
    color: var(--color-accent);
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 1px;
    padding-top: 0.55rem;
    transition: background-color 0.2s ease, transform 0.2s ease;
  }
  .nav-dropdown__item:hover .nav-dropdown__item-icon {
    background-color: var(--color-accent);
    color: white;
    transform: scale(1.04);
  }
  .nav-dropdown__item-size {
    font-family: 'DM Serif Display', serif;
    font-size: 1.5rem;
    line-height: 1;
  }
  .nav-dropdown__item-unit {
    font-family: 'Outfit', sans-serif;
    font-size: 0.5625rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.8;
  }

  .nav-dropdown__item-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
  }
  .nav-dropdown__item-name {
    font-family: 'Outfit', sans-serif;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text);
    line-height: 1.2;
  }
  .nav-dropdown__item-desc {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    line-height: 1.3;
  }

  .nav-dropdown__item-arrow {
    flex-shrink: 0;
    color: var(--color-text-muted);
    opacity: 0;
    transform: translateX(-4px);
    transition: opacity 0.2s ease, transform 0.2s ease, color 0.2s ease;
  }
  .nav-dropdown__item:hover .nav-dropdown__item-arrow {
    opacity: 1;
    transform: translateX(0);
    color: var(--color-accent);
  }

  .nav-dropdown__footer {
    margin-top: 0.5rem;
    padding: 0.625rem 0.75rem 0.125rem;
    border-top: 1px solid var(--color-border);
    padding-top: 0.875rem;
  }
  .nav-dropdown__footer-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'Outfit', sans-serif;
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--color-accent);
    text-decoration: none;
    transition: gap 0.2s ease;
  }
  .nav-dropdown__footer-link:hover {
    gap: 0.6rem;
  }

  /* Mobile collapsible */
  .mobile-oferta-toggle.is-open .mobile-oferta-chevron {
    transform: rotate(180deg);
  }
</style>

<script is:inline>
  // Theme toggle
  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    document.documentElement.classList.toggle('dark');
    localStorage.setItem(
      'theme',
      document.documentElement.classList.contains('dark') ? 'dark' : 'light'
    );
  });

  // Mobile menu
  const menuToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  let menuOpen = false;

  menuToggle?.addEventListener('click', () => {
    menuOpen = !menuOpen;
    if (menuOpen) {
      mobileMenu.classList.remove('pointer-events-none', 'opacity-0', '-translate-y-4');
      mobileMenu.classList.add('pointer-events-auto', 'opacity-100', 'translate-y-0');
      document.body.style.overflow = 'hidden';
    } else {
      mobileMenu.classList.add('pointer-events-none', 'opacity-0', '-translate-y-4');
      mobileMenu.classList.remove('pointer-events-auto', 'opacity-100', 'translate-y-0');
      document.body.style.overflow = '';
    }
  });

  document.querySelectorAll('.mobile-nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      menuOpen = false;
      mobileMenu.classList.add('pointer-events-none', 'opacity-0', '-translate-y-4');
      mobileMenu.classList.remove('pointer-events-auto', 'opacity-100', 'translate-y-0');
      document.body.style.overflow = '';
    });
  });

  // Mobile "Oferta" expandable submenu
  document.querySelectorAll('.mobile-oferta-toggle').forEach((btn) => {
    btn.addEventListener('click', () => {
      const panel = btn.nextElementSibling;
      const isOpen = btn.classList.toggle('is-open');
      btn.setAttribute('aria-expanded', String(isOpen));
      if (isOpen) {
        panel.style.maxHeight = panel.scrollHeight + 'px';
      } else {
        panel.style.maxHeight = '0';
      }
    });
  });

  // Desktop dropdown: click-to-toggle on the chevron (keeps the link itself navigable)
  document.querySelectorAll('.nav-dropdown').forEach((dd) => {
    const trigger = dd.querySelector('.nav-dropdown__trigger');
    const chevron = dd.querySelector('.nav-dropdown__chevron');
    chevron?.addEventListener('click', (e) => {
      e.preventDefault();
      e.stopPropagation();
      dd.classList.toggle('is-open');
      const expanded = dd.classList.contains('is-open');
      trigger?.setAttribute('aria-expanded', String(expanded));
    });
  });
  document.addEventListener('click', (e) => {
    document.querySelectorAll('.nav-dropdown.is-open').forEach((dd) => {
      if (!dd.contains(e.target)) {
        dd.classList.remove('is-open');
        dd.querySelector('.nav-dropdown__trigger')?.setAttribute('aria-expanded', 'false');
      }
    });
  });

  // Navbar scroll effect
  let lastScroll = 0;
  window.addEventListener('scroll', () => {
    const navbar = document.getElementById('navbar');
    const scrollY = window.scrollY;
    if (scrollY > 80) {
      navbar.style.borderBottom = `1px solid var(--color-border)`;
    } else {
      navbar.style.borderBottom = 'none';
    }
    lastScroll = scrollY;
  }, { passive: true });
</script>
