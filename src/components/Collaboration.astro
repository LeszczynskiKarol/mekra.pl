---
const audiences = [
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" /></svg>`,
    title: 'Klienci indywidualni',
    description: 'Szukasz frontów do nowej kuchni, szafy czy zabudowy? Doradzimy, wymierzymy i wyprodukujemy fronty idealnie dopasowane do Twojego wnętrza. Możliwość wymiany samych frontów bez ruszania korpusów.',
    features: ['Wycena na podstawie wymiarów', 'Pomiar u klienta', 'Montaż i wymiana frontów', 'Doradztwo materiałowe'],
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17l-5.658 3.286a.75.75 0 01-1.118-.791l1.399-6.352-4.938-4.27a.75.75 0 01.427-1.316l6.486-.548 2.554-6.014a.75.75 0 011.356 0l2.554 6.014 6.486.548a.75.75 0 01.427 1.316l-4.938 4.27 1.399 6.352a.75.75 0 01-1.118.791l-5.658-3.286z" /></svg>`,
    title: 'Stolarze',
    description: 'Rozszerz swoją ofertę o fronty ramiakowe z płyty laminowanej. Współpracujemy z warsztatami stolarskimi w regionie — dostarczamy gotowe fronty do Twoich korpusów.',
    features: ['Hurtowe warunki cenowe', 'Szybka realizacja zleceń', 'Wsparcie techniczne', 'Regularny łańcuch dostaw'],
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 3.75h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008zm0 3h.008v.008h-.008v-.008z" /></svg>`,
    title: 'Projektanci wnętrz',
    description: 'Oferujemy szkolenia produktowe i pełne wsparcie przy wdrażaniu frontów ramiakowych w Twoich projektach. Idealna alternatywa dla lakierów — z lepszą trwałością i niższą ceną.',
    features: ['Szkolenia produktowe', 'Próbki materiałów', 'Wsparcie przy projektach', 'Konkurencyjna alternatywa dla lakieru'],
  },
];
---

<section id="wspolpraca" class="section-spacing section-padding relative" style="background-color: var(--color-bg-secondary);">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto animate-on-scroll">
      <span class="label-tag">Współpraca</span>
      <h2 class="mt-6 font-display text-3xl sm:text-4xl md:text-5xl tracking-tight" style="color: var(--color-text);">
        Dla kogo<br />
        <span class="text-gradient">pracujemy?</span>
      </h2>
    </div>

    <!-- Audience cards -->
    <div class="mt-16 grid md:grid-cols-3 gap-6">
      {audiences.map((audience, i) => (
        <div
          class="animate-on-scroll card-base rounded-2xl p-6 md:p-8 flex flex-col"
          style={`transition-delay: ${i * 0.15}s;`}
        >
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center" style="background-color: var(--color-bg-tertiary); color: var(--color-accent);">
            <Fragment set:html={audience.icon} />
          </div>

          <h3 class="mt-6 font-heading text-xl font-semibold" style="color: var(--color-text);">
            {audience.title}
          </h3>

          <p class="mt-3 text-sm leading-relaxed font-body flex-1" style="color: var(--color-text-secondary);">
            {audience.description}
          </p>

          <ul class="mt-6 space-y-2.5">
            {audience.features.map((feature) => (
              <li class="flex items-start gap-2.5 text-sm font-body" style="color: var(--color-text-secondary);">
                <svg class="w-4 h-4 flex-shrink-0 mt-0.5" style="color: var(--color-accent);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
                </svg>
                {feature}
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
