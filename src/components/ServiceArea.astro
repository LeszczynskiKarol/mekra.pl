---
// Service area section
---

<section class="section-spacing section-padding relative">
  <div class="max-w-7xl mx-auto">
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
      <!-- Content -->
      <div class="animate-on-scroll">
        <span class="label-tag">Zamów z wymiarem</span>

        <h2 class="mt-6 font-display text-3xl sm:text-4xl md:text-5xl tracking-tight leading-tight" style="color: var(--color-text);">
          Toruń i&nbsp;okolice —<br />
          <span class="text-gradient">wymierzymy i&nbsp;dostarczymy</span>
        </h2>

        <div class="mt-8 space-y-5 text-base leading-relaxed font-body" style="color: var(--color-text-secondary);">
          <p>
            Oferujemy kompleksową obsługę — od pomiaru, przez produkcję, po dostawę
            i&nbsp;montaż. Możesz podać własne wymiary lub zamówić wymiarowanie przez
            nasz zespół bezpośrednio u&nbsp;Ciebie.
          </p>
          <p>
            Oprócz samych frontów oferujemy wymianę wraz z&nbsp;zawiasami — pamiętaj
            jednak, że nasze fronty ramiakowe mają grubość 22&nbsp;mm, co oznacza
            niewielką różnicę w&nbsp;płaszczyźnie względem standardowych frontów 18-19&nbsp;mm.
          </p>
        </div>

        <!-- Service steps -->
        <div class="mt-10 space-y-4">
          {[
            { step: '01', title: 'Kontakt i wycena', desc: 'Podaj wymiary lub umów się na pomiar' },
            { step: '02', title: 'Dobór materiału', desc: 'Wybierz płytę, kolor i szerokość ramki' },
            { step: '03', title: 'Produkcja', desc: 'Precyzyjna realizacja zamówienia' },
            { step: '04', title: 'Dostawa i montaż', desc: 'Dowozimy i montujemy na miejscu' },
          ].map((item, i) => (
            <div class="flex items-start gap-4 group">
              <span class="flex-shrink-0 font-display text-2xl" style="color: var(--color-accent); opacity: 0.5;">{item.step}</span>
              <div>
                <h4 class="font-heading font-semibold text-sm" style="color: var(--color-text);">{item.title}</h4>
                <p class="text-sm font-body" style="color: var(--color-text-secondary);">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Map / delivery area -->
      <div class="animate-on-scroll" style="transition-delay: 0.2s;">
        <div class="card-base rounded-2xl p-8 md:p-10 text-center">
          <div class="w-16 h-16 mx-auto rounded-2xl flex items-center justify-center" style="background-color: var(--color-bg-tertiary); color: var(--color-accent);">
            <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
            </svg>
          </div>

          <h3 class="mt-6 font-display text-2xl" style="color: var(--color-text);">Zasięg usług</h3>

          <div class="mt-6 space-y-3">
            <div class="rounded-xl p-4" style="background-color: var(--color-bg-tertiary); border: 1px solid var(--color-border);">
              <div class="font-heading font-semibold text-sm" style="color: var(--color-accent);">Pomiar + dostawa + montaż</div>
              <div class="text-sm font-body mt-1" style="color: var(--color-text-secondary);">Toruń i okolice</div>
            </div>
            <div class="rounded-xl p-4" style="background-color: var(--color-bg-tertiary); border: 1px solid var(--color-border);">
              <div class="font-heading font-semibold text-sm" style="color: var(--color-accent);">Dostawa frontów</div>
              <div class="text-sm font-body mt-1" style="color: var(--color-text-secondary);">Województwo kujawsko-pomorskie</div>
            </div>
            <div class="rounded-xl p-4" style="background-color: var(--color-bg-tertiary); border: 1px solid var(--color-border);">
              <div class="font-heading font-semibold text-sm" style="color: var(--color-accent);">Wysyłka</div>
              <div class="text-sm font-body mt-1" style="color: var(--color-text-secondary);">Cała Polska — na zamówienie</div>
            </div>
          </div>

          <a href="#kontakt" class="mt-8 btn-primary inline-flex">Zamów pomiar</a>
        </div>
      </div>
    </div>
  </div>
</section>
