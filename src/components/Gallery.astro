---
import manifest from '../data/realizacje.json';

const { categories, items, counts } = manifest;

/**
 * Build hero tiles for the bento grid — one tile per category, hero photo
 * = first item of that category.
 *
 * Layout is fixed (matches the four frame sizes from Products.astro plus
 * the "zabudowy specjalne" tile):
 *
 *   Desktop (12 cols):                   Mobile (1 col):
 *   ┌──────────────┬──────┐               ┌──────────────┐
 *   │              │ 7mm  │               │   36 mm      │
 *   │   36 mm      ├──────┤               ├──────────────┤
 *   │   (hero)     │ 18mm │               │   7 mm       │
 *   ├───────┬──────┴──────┤               ├──────────────┤
 *   │ 60mm  │  zabudowy   │               │   18 mm      │
 *   └───────┴─────────────┘               ├──────────────┤
 *                                         │   60 mm      │
 *                                         ├──────────────┤
 *                                         │   zabudowy   │
 *                                         └──────────────┘
 */
const layoutOrder = ['ramka-36mm', 'ramka-7mm', 'ramka-18mm', 'ramka-60mm', 'zabudowy'];

// span classes per category slug
const SPAN = {
  'ramka-36mm':  'lg:col-span-8 lg:row-span-2',
  'ramka-7mm':   'lg:col-span-4 lg:row-span-1',
  'ramka-18mm':  'lg:col-span-4 lg:row-span-1',
  'ramka-60mm':  'lg:col-span-5 lg:row-span-1',
  'zabudowy':    'lg:col-span-7 lg:row-span-1',
};

// frame size big label (extracted from category)
const SIZE_LABEL = {
  'ramka-7mm':  { size: '7',  unit: 'mm' },
  'ramka-18mm': { size: '18', unit: 'mm' },
  'ramka-36mm': { size: '36', unit: 'mm' },
  'ramka-60mm': { size: '60', unit: 'mm' },
  'zabudowy':   { size: '★',  unit: '' },
};

const tiles = layoutOrder.map((slug) => {
  const cat = categories[slug];
  const heroItem = items.find((it) => it.category === slug);
  return {
    slug,
    title: cat.title,
    subtitle: cat.subtitle,
    description: cat.description,
    count: cat.count,
    heroItem,
    span: SPAN[slug],
    label: SIZE_LABEL[slug],
  };
});

const totalCount = counts.total;
---

<section id="realizacje" class="section-spacing section-padding relative" style="background-color: var(--color-bg-secondary);">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto animate-on-scroll">
      <span class="label-tag">Realizacje</span>
      <h2 class="mt-6 font-display text-3xl sm:text-4xl md:text-5xl tracking-tight" style="color: var(--color-text);">
        Tak wyglądają<br />
        <span class="text-gradient">nasze ramki w Twoich wnętrzach</span>
      </h2>
      <p class="mt-6 text-base md:text-lg leading-relaxed font-body" style="color: var(--color-text-secondary);">
        {totalCount} realizacji posegregowanych według szerokości ramki — od minimalistycznych
        7&nbsp;mm po pełną klasykę 60&nbsp;mm. Kliknij kategorię, żeby zobaczyć wszystko.
      </p>
    </div>

    <!-- Bento grid: one tile per category -->
    <div class="mt-16 grid grid-cols-1 lg:grid-cols-12 gap-4 auto-rows-[280px] sm:auto-rows-[320px]">
      {tiles.map((tile, i) => (
        <a
          href={`/realizacje/#${tile.slug}`}
          class={`category-tile animate-on-scroll group relative rounded-2xl overflow-hidden ${tile.span}`}
          style={`transition-delay: ${i * 0.08}s;`}
          aria-label={`Zobacz realizacje: ${tile.title} (${tile.count} zdjęć)`}
        >
          {tile.heroItem && (
            <picture>
              <source srcset={tile.heroItem.paths.fullWebp} type="image/webp" />
              <img
                src={tile.heroItem.paths.full}
                alt={`${tile.title} — ${tile.subtitle}`}
                class="category-tile__img"
                loading="lazy"
                decoding="async"
              />
            </picture>
          )}

          <!-- Permanent bottom gradient + content -->
          <div class="category-tile__overlay">
            <div class="category-tile__top">
              <span class="category-tile__count">{tile.count} realizacji</span>
            </div>

            <div class="category-tile__bottom">
              <div class="category-tile__size">
                <span class="category-tile__size-num">{tile.label.size}</span>
                <span class="category-tile__size-unit">{tile.label.unit}</span>
              </div>
              <div class="category-tile__meta">
                <h3 class="category-tile__title">{tile.title}</h3>
                <p class="category-tile__subtitle">{tile.subtitle}</p>
              </div>
              <div class="category-tile__arrow">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
                </svg>
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-12 text-center animate-on-scroll">
      <a
        href="/realizacje/"
        class="inline-flex items-center gap-2 btn-primary"
      >
        <span>Zobacz wszystkie realizacje ({totalCount})</span>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </div>
</section>

<style>
  .category-tile {
    display: block;
    cursor: pointer;
    isolation: isolate;
    text-decoration: none;
    background-color: #1a1a1a;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1),
                box-shadow 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .category-tile:hover {
    transform: translateY(-4px);
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.25);
  }

  .category-tile__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    transition: transform 0.9s cubic-bezier(0.4, 0, 0.2, 1),
                filter 0.5s ease;
    filter: saturate(0.95) brightness(0.92);
  }
  .category-tile:hover .category-tile__img {
    transform: scale(1.06);
    filter: saturate(1.1) brightness(1);
  }

  .category-tile__overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.85) 0%,
      rgba(0, 0, 0, 0.5) 30%,
      rgba(0, 0, 0, 0.1) 60%,
      rgba(0, 0, 0, 0.35) 100%
    );
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 1.5rem;
    transition: background 0.4s ease;
  }
  @media (min-width: 1024px) {
    .category-tile__overlay { padding: 1.75rem; }
  }
  .category-tile:hover .category-tile__overlay {
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.9) 0%,
      rgba(0, 0, 0, 0.55) 30%,
      rgba(0, 0, 0, 0.15) 60%,
      rgba(0, 0, 0, 0.4) 100%
    );
  }

  .category-tile__top {
    display: flex;
    justify-content: flex-end;
  }
  .category-tile__count {
    display: inline-block;
    padding: 0.35rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.625rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: white;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.18);
  }

  .category-tile__bottom {
    display: flex;
    align-items: flex-end;
    gap: 1rem;
    color: white;
  }

  .category-tile__size {
    display: flex;
    align-items: baseline;
    gap: 0.2rem;
    line-height: 1;
    flex-shrink: 0;
  }
  .category-tile__size-num {
    font-family: 'DM Serif Display', serif;
    font-size: 3rem;
    line-height: 1;
    letter-spacing: -0.02em;
  }
  @media (min-width: 1024px) {
    .category-tile__size-num { font-size: 4rem; }
  }
  .category-tile__size-unit {
    font-family: 'Outfit', sans-serif;
    font-size: 0.875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0.7;
  }

  .category-tile__meta {
    flex: 1;
    min-width: 0;
  }
  .category-tile__title {
    font-family: 'Outfit', sans-serif;
    font-weight: 600;
    font-size: 1.125rem;
    line-height: 1.2;
    margin: 0;
  }
  .category-tile__subtitle {
    font-family: 'Outfit', sans-serif;
    font-size: 0.75rem;
    margin: 0.25rem 0 0 0;
    opacity: 0.7;
    letter-spacing: 0.02em;
  }

  .category-tile__arrow {
    flex-shrink: 0;
    width: 2.5rem;
    height: 2.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.12);
    border: 1px solid rgba(255, 255, 255, 0.18);
    transition: transform 0.3s ease, background 0.3s ease;
  }
  .category-tile:hover .category-tile__arrow {
    background: rgba(255, 255, 255, 0.22);
    transform: translateX(4px);
  }

  /* Bigger hero tile gets a bigger size label */
  .category-tile.lg\:col-span-8 .category-tile__size-num,
  .category-tile:nth-child(1) .category-tile__size-num {
    font-size: 4rem;
  }
  @media (min-width: 1024px) {
    .category-tile.lg\:col-span-8 .category-tile__size-num,
    .category-tile:nth-child(1) .category-tile__size-num {
      font-size: 6rem;
    }
  }
</style>
