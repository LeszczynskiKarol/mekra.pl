---
import manifest from '../data/realizacje.json';

/**
 * Hero set for the home page: pick first 4 from each category for variety.
 * Full gallery lives at /realizacje/.
 */
const HERO_PER_CATEGORY = 4;
const heroItems = Object.keys(manifest.categories).flatMap((catSlug) => {
  return manifest.items
    .filter((it) => it.category === catSlug)
    .slice(0, HERO_PER_CATEGORY);
});

// Row-span pattern for visual rhythm in the grid
const spanPattern = ['row-span-2', '', '', '', '', 'row-span-2', '', '', '', '', '', 'row-span-2'];
const galleryItems = heroItems.map((it, i) => ({
  ...it,
  caption: it.project,
  span: spanPattern[i % spanPattern.length],
}));

const totalCount = manifest.counts.total;
---

<section id="realizacje" class="section-spacing section-padding relative" style="background-color: var(--color-bg-secondary);">
  <div class="max-w-7xl mx-auto">
    <!-- Header -->
    <div class="text-center max-w-3xl mx-auto animate-on-scroll">
      <span class="label-tag">Realizacje</span>
      <h2 class="mt-6 font-display text-3xl sm:text-4xl md:text-5xl tracking-tight" style="color: var(--color-text);">
        Nasze fronty<br />
        <span class="text-gradient">w Twoich wnętrzach</span>
      </h2>
      <p class="mt-6 text-base md:text-lg leading-relaxed font-body" style="color: var(--color-text-secondary);">
        Kuchnie, szafy, zabudowy — zobacz, jak płyta laminowana zamienia
        proste formy w&nbsp;coś wyjątkowego. Każda realizacja to dowód na to,
        że materiał ma znaczenie.
      </p>
    </div>

    <!-- Gallery grid -->
    <div class="mt-16 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 auto-rows-[280px]">
      {galleryItems.map((item, i) => (
        <div
          class={`animate-on-scroll group relative rounded-2xl overflow-hidden cursor-pointer gallery-thumb ${item.span}`}
          style={`transition-delay: ${i * 0.06}s;`}
          data-gallery-index={i}
          role="button"
          tabindex="0"
          aria-label={`Otwórz zdjęcie: ${item.caption}`}
        >
          <picture>
            <source srcset={item.paths.thumbWebp} type="image/webp" />
            <img
              src={item.paths.thumb}
              alt={item.alt}
              width={item.thumbWidth}
              height={item.thumbHeight}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
              loading="lazy"
              decoding="async"
            />
          </picture>
          <!-- Overlay -->
          <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500">
            <div class="absolute bottom-0 left-0 right-0 p-6 flex items-end justify-between">
              <p class="text-white font-heading font-medium text-sm translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
                {item.caption}
              </p>
              <svg class="w-5 h-5 text-white/70 translate-y-4 group-hover:translate-y-0 transition-transform duration-500 delay-75 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3.75v4.5m0-4.5h4.5m-4.5 0L9 9M3.75 20.25v-4.5m0 4.5h4.5m-4.5 0L9 15M20.25 3.75h-4.5m4.5 0v4.5m0-4.5L15 9m5.25 11.25h-4.5m4.5 0v-4.5m0 4.5L15 15" />
                </svg>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- CTA: zobacz wszystkie -->
    <div class="mt-12 text-center animate-on-scroll">
      <a
        href="/realizacje/"
        class="inline-flex items-center gap-2 btn-primary !py-3 !px-7"
      >
        <span>Zobacz wszystkie realizacje ({totalCount})</span>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </div>
</section>

<!-- Lightbox Modal -->
<div id="gallery-lightbox" class="gallery-lightbox" aria-hidden="true" role="dialog" aria-label="Podgląd zdjęcia">
  <div class="gallery-lightbox__backdrop" data-lightbox-close></div>

  <button class="gallery-lightbox__close" data-lightbox-close aria-label="Zamknij">
    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <button class="gallery-lightbox__nav gallery-lightbox__nav--prev" data-lightbox-prev aria-label="Poprzednie zdjęcie">
    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5L8.25 12l7.5-7.5" />
    </svg>
  </button>

  <button class="gallery-lightbox__nav gallery-lightbox__nav--next" data-lightbox-next aria-label="Następne zdjęcie">
    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M8.25 4.5l7.5 7.5-7.5 7.5" />
    </svg>
  </button>

  <div class="gallery-lightbox__content">
    <picture>
      <source id="lightbox-img-webp" srcset="" type="image/webp" />
      <img id="lightbox-img" class="gallery-lightbox__img" src="" alt="" />
    </picture>
    <div class="gallery-lightbox__caption">
      <p id="lightbox-caption" class="font-heading font-medium text-sm text-white"></p>
      <p id="lightbox-counter" class="text-xs text-white/50 mt-1 font-body"></p>
    </div>
  </div>
</div>

<style>
  .gallery-lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.35s cubic-bezier(0.4, 0, 0.2, 1),
                visibility 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .gallery-lightbox.is-open {
    pointer-events: auto;
    opacity: 1;
    visibility: visible;
  }
  .gallery-lightbox__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }
  .gallery-lightbox__close {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    z-index: 10;
    width: 2.75rem;
    height: 2.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.1);
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.15);
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
  }
  .gallery-lightbox__close:hover {
    background: rgba(255, 255, 255, 0.2);
    transform: scale(1.05);
  }
  .gallery-lightbox__nav {
    position: absolute;
    top: 50%;
    z-index: 10;
    transform: translateY(-50%);
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    background: rgba(255, 255, 255, 0.08);
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.12);
    cursor: pointer;
    transition: background 0.2s, transform 0.2s;
  }
  .gallery-lightbox__nav:hover { background: rgba(255, 255, 255, 0.18); }
  .gallery-lightbox__nav--prev { left: 1rem; }
  .gallery-lightbox__nav--next { right: 1rem; }
  @media (min-width: 768px) {
    .gallery-lightbox__nav--prev { left: 1.5rem; }
    .gallery-lightbox__nav--next { right: 1.5rem; }
    .gallery-lightbox__close { top: 1.5rem; right: 1.5rem; }
  }
  .gallery-lightbox__content {
    position: relative;
    z-index: 5;
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: calc(100vw - 6rem);
    max-height: calc(100vh - 6rem);
  }
  @media (max-width: 767px) {
    .gallery-lightbox__content {
      max-width: calc(100vw - 1.5rem);
      max-height: calc(100vh - 4rem);
    }
  }
  .gallery-lightbox__img {
    max-width: 100%;
    max-height: calc(100vh - 10rem);
    object-fit: contain;
    border-radius: 0.75rem;
    box-shadow: 0 25px 60px rgba(0, 0, 0, 0.5);
    transform: scale(0.92) translateY(12px);
    opacity: 0;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1),
                opacity 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .gallery-lightbox.is-open .gallery-lightbox__img {
    transform: scale(1) translateY(0);
    opacity: 1;
  }
  .gallery-lightbox__img.is-switching {
    transform: scale(0.96);
    opacity: 0;
    transition-duration: 0.18s;
  }
  .gallery-lightbox__caption {
    text-align: center;
    margin-top: 1rem;
    transform: translateY(8px);
    opacity: 0;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1) 0.1s,
                opacity 0.35s cubic-bezier(0.4, 0, 0.2, 1) 0.1s;
  }
  .gallery-lightbox.is-open .gallery-lightbox__caption {
    transform: translateY(0);
    opacity: 1;
  }
  .gallery-lightbox__caption.is-switching {
    opacity: 0;
    transform: translateY(4px);
    transition-duration: 0.15s;
    transition-delay: 0s;
  }
</style>

<script define:vars={{ galleryItems }}>
  document.addEventListener('DOMContentLoaded', () => {
    const lightbox = document.getElementById('gallery-lightbox');
    const lbImg = document.getElementById('lightbox-img');
    const lbWebp = document.getElementById('lightbox-img-webp');
    const lbCaption = document.getElementById('lightbox-caption');
    const lbCounter = document.getElementById('lightbox-counter');
    const thumbs = document.querySelectorAll('#realizacje .gallery-thumb');
    const total = galleryItems.length;
    let currentIndex = 0;
    let isAnimating = false;

    function applyImage(item) {
      lbWebp.srcset = item.paths.fullWebp;
      lbImg.src = item.paths.full;
      lbImg.alt = item.alt;
      lbCaption.textContent = item.caption;
      lbCounter.textContent = `${currentIndex + 1} / ${total}`;
    }

    function openLightbox(index) {
      currentIndex = index;
      applyImage(galleryItems[currentIndex]);
      lightbox.classList.add('is-open');
      lightbox.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    }

    function closeLightbox() {
      lightbox.classList.remove('is-open');
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }

    function transitionTo(newIndex) {
      if (isAnimating) return;
      isAnimating = true;
      lbImg.classList.add('is-switching');
      lbCaption.parentElement.classList.add('is-switching');
      setTimeout(() => {
        currentIndex = newIndex;
        applyImage(galleryItems[currentIndex]);
        requestAnimationFrame(() => {
          lbImg.classList.remove('is-switching');
          lbCaption.parentElement.classList.remove('is-switching');
          setTimeout(() => { isAnimating = false; }, 300);
        });
      }, 200);
    }

    function goNext() { transitionTo((currentIndex + 1) % total); }
    function goPrev() { transitionTo((currentIndex - 1 + total) % total); }

    thumbs.forEach((thumb) => {
      thumb.addEventListener('click', () => {
        const idx = parseInt(thumb.dataset.galleryIndex, 10);
        openLightbox(idx);
      });
      thumb.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          const idx = parseInt(thumb.dataset.galleryIndex, 10);
          openLightbox(idx);
        }
      });
    });

    document.querySelectorAll('[data-lightbox-close]').forEach((el) => {
      el.addEventListener('click', closeLightbox);
    });
    document.querySelector('[data-lightbox-prev]').addEventListener('click', goPrev);
    document.querySelector('[data-lightbox-next]').addEventListener('click', goNext);

    document.addEventListener('keydown', (e) => {
      if (!lightbox.classList.contains('is-open')) return;
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowRight') goNext();
      if (e.key === 'ArrowLeft') goPrev();
    });

    let touchStartX = 0;
    let touchEndX = 0;
    lightbox.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });
    lightbox.addEventListener('touchend', (e) => {
      touchEndX = e.changedTouches[0].screenX;
      const diff = touchStartX - touchEndX;
      if (Math.abs(diff) > 50) {
        if (diff > 0) goNext(); else goPrev();
      }
    }, { passive: true });
  });
</script>
